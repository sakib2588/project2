          }
        }
      }
    },
    {
      "id": "wfb-014",
      "name": "Generate Exhausted Fallback Email",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1,
      "position": [
        1980,
        400
      ],
      "parameters": {
        "promptType": "define",
        "text": "=You are an elite real estate broker assistant writing a last-chance outreach email to a lead we could not reach by phone after 3 attempts.\n\nLead details:\n- Name: {{ $json.full_name }}\n- Property Interest: ${{ $json.property_value }}\n- Tier: {{ $json.lead_tier }}\n\nWrite a warm, personalised HTML email body. Do NOT mention phone calls or failed attempts. Express genuine interest. Keep under 110 words. Offer to connect on their schedule.\n\nOUTPUT CONTRACT:\n1. First character MUST be < (an HTML tag, no preamble)\n2. No ```html fences, no markdown, no subject line\n3. Close with a proper HTML block tag\n\nBegin HTML now:"
      }
    },
    {
      "id": "wfb-015",
      "name": "Sanitize Fallback Email LLM Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        400
      ],
      "parameters": {
        "jsCode": "const raw = ($input.first().json.text || '').trim();\nconst lead = $('Merge Call Data + Lead Record').first().json;\n\nlet html = raw.replace(/```[a-z]*\\s*/gi, '').replace(/```/g, '').trim();\nconst firstTag = html.indexOf('<');\nif (firstTag > 0) html = html.slice(firstTag);\n\nconst hasHtml = /<[a-z][^>]*>/i.test(html);\nconst firstName = lead.full_name.split(' ')[0];\n\nif (!hasHtml || html.length < 50) {\n  html = `<p>Dear ${firstName},</p><p>We've been trying to connect with you regarding your property interest at the $${lead.property_value} level. We'd love to help â€” please book a time that works for you.</p>`;\n}\n\nreturn [{ json: { ...lead, sanitized_fallback_html: html, first_name: firstName } }];"
      }
    },
    {
      "id": "wfb-016",
      "name": "Send Fallback Email (3 Strikes)",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [
        2420,
        400
      ],
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=We'd love to connect, {{ $json.first_name }}",
        "emailType": "html",
        "message": "={{ $json.sanitized_fallback_html }}<br><br><a href=\"{{ $env.CALENDAR_LINK }}\" style=\"display:inline-block;background:#1a1a2e;color:#fff;padding:13px 28px;border-radius:5px;text-decoration:none;font-family:Arial,sans-serif;\">Book at Your Convenience â†’</a>"
      }
    },
    {
      "id": "wfb-017",
      "name": "CRM Update â€” All Attempts Exhausted",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        2640,
        400
      ],
      "parameters": {
        "operation": "update",
        "documentId": "={{ $env.GOOGLE_SHEET_ID }}",
        "sheetName": "Leads",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "lead_id": "={{ $json.lead_id }}",
