          }
        }
      }
    },
    {
      "id": "wfb-021",
      "name": "Slack â€” Unknown Call State (Ops)",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [
        1320,
        680
      ],
      "parameters": {
        "authentication": "oAuth2",
        "channel": "#ops-alerts",
        "text": "=:question: *Unknown Retell Call State â€” Needs Manual Review*\n\n:id: *Call ID:* {{ $json.call_id }}\n:bust_in_silhouette: *Lead:* {{ $json.lead_id }}\n:warning: *call_status:* {{ $json.call_status }}\n:warning: *disconnection_reason:* {{ $json.disconnection_reason }}\n:repeat: *Attempt:* {{ $json.attempt_number }}\n\nThis state is not in our routing logic. Lead has been paused pending manual review."
      }
    },
    {
      "id": "wfb-022",
      "name": "CRM Update â€” Unknown State",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        1540,
        680
      ],
      "parameters": {
        "operation": "update",
        "documentId": "={{ $env.GOOGLE_SHEET_ID }}",
        "sheetName": "Leads",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "lead_id": "={{ $json.lead_id }}",
            "status": "=unknown_state_manual_review",
            "last_updated": "={{ new Date().toISOString() }}"
          }
        }
      }
    },
    {
      "id": "wfb-011b",
      "name": "Check Business Hours (Retry)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2040,
        160
      ],
      "parameters": {
        "jsCode": "const lead = $input.first().json;\nconst tz = $env.BUSINESS_TIMEZONE || 'America/New_York';\nconst now = new Date();\nconst localStr = now.toLocaleString('en-US', { timeZone: tz });\nconst local = new Date(localStr);\nconst hour = local.getHours();\nconst day = local.getDay();\n\nconst isWeekday = day >= 1 && day <= 5;\nconst isSaturday = day === 6;\nconst isWeekdayHours = isWeekday && hour >= 9 && hour < 20;\nconst isSaturdayHours = isSaturday && hour >= 10 && hour < 16;\nconst can_call_now = isWeekdayHours || isSaturdayHours;\n\nlet resume_at = null;\nif (!can_call_now) {\n  const next = new Date(local);\n  let openHour = isSaturday ? 10 : 9;\n  next.setHours(openHour, 0, 0, 0);\n  if (hour >= 20 || (isSaturday && hour >= 16)) next.setDate(next.getDate() + 1);\n  if (next.getDay() === 0) next.setDate(next.getDate() + 1);\n  if (next.getDay() === 6) openHour = 10; else openHour = 9;\n  next.setHours(openHour, 0, 0, 0);\n  resume_at = next.toISOString();\n}\n\nreturn [{ json: { ...lead, can_call_now, resume_at } }];"
      }
    },
    {
      "id": "wfb-011c",
      "name": "Can Call Now (Retry)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2220,
        160
      ],
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "operator": {
                "operation": "true",
                "type": "boolean"
              },
              "rightValue": true,
              "id": "cond-retry-call-now",
              "leftValue": "={{ $json.can_call_now }}"
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "wfb-011d",
      "name": "Wait Until Business Hours (Retry)",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [
        2380,
        60
      ],
      "parameters": {
        "dateTime": "={{ $json.resume_at }}",
        "resume": "specificTime"
      },
      "webhookId": "wfb-retry-biz-hours-wait"
    }
  ],
  "connections": {
    "Retell Call Webhook": {
      "main": [
        [
          {
            "node": "Validate & Classify Call Outcome",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Validate & Classify Call Outcome": {
      "main": [
        [
