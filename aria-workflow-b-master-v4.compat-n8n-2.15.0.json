      ],
      "parameters": {
        "authentication": "oAuth2",
        "channel": "#leads-live",
        "text": "=:fire: *HOT LEAD â€” Call Answered (Attempt {{ $json.attempt_number }})*\n\n:bust_in_silhouette: *Name:* {{ $json.full_name }}\n:star: *Tier:* {{ $json.lead_tier }} | Score: {{ $json.lead_score }}/100\n:telephone_receiver: *Phone:* {{ $json.phone }}\n:moneybag: *Property:* ${{ $json.property_value }}\n:stopwatch: *Duration:* {{ $json.call_duration_sec }}s\n:bar_chart: *Sentiment:* {{ $json.user_sentiment }}\n:speech_balloon: *Summary:* {{ $json.call_summary || 'No summary available' }}\n:id: *Lead ID:* {{ $json.lead_id }}\n\n@here â€” Follow up NOW while they are warm."
      }
    },
    {
      "id": "wfb-008",
      "name": "Prepare Retry Config (Voicemail)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        220
      ],
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst next_attempt = d.attempt_number + 1;\n// Attempt 1â†’2: wait 2 hours. Attempt 2â†’3: wait 24 hours.\nconst wait_hours = d.attempt_number === 1 ? 2 : 24;\nconst script_hook = next_attempt === 2 ? 'second_contact' : 'final_contact';\nconst attempts_exhausted = d.attempt_number >= 3;\nreturn [{ json: { ...d, next_attempt, wait_hours, script_hook, attempts_exhausted } }];"
      }
    },
    {
      "id": "wfb-008b",
      "name": "Prepare Retry Config (No Answer)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        340
      ],
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst next_attempt = d.attempt_number + 1;\nconst wait_hours = d.attempt_number === 1 ? 2 : 24;\nconst script_hook = next_attempt === 2 ? 'second_contact' : 'final_contact';\nconst attempts_exhausted = d.attempt_number >= 3;\nreturn [{ json: { ...d, next_attempt, wait_hours, script_hook, attempts_exhausted } }];"
      }
    },
    {
