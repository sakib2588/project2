    {
      "id": "wfb-012",
      "name": "Trigger Retell â€” Next Attempt",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        2200,
        160
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.retellai.com/v2/create-phone-call",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"from_number\": \"{{ $env.RETELL_FROM_NUMBER }}\",\n  \"to_number\": \"{{ $json.phone }}\",\n  \"agent_id\": \"{{ $env.RETELL_AGENT_ID }}\",\n  \"retell_llm_dynamic_variables\": {\n    \"customer_name\": \"{{ $json.full_name }}\",\n    \"property_value\": \"{{ $json.property_value }}\",\n    \"lead_tier\": \"{{ $json.lead_tier }}\",\n    \"script_hook\": \"{{ $json.script_hook }}\",\n    \"lead_id\": \"{{ $json.lead_id }}\",\n    \"attempt_number\": \"{{ $json.next_attempt }}\"\n  }\n}",
        "retryOnFail": true,
        "maxTries": 3,
        "waitBetweenTries": 5000,
        "sendHeaders": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerParametersUi": {
          "parameter": [
            {
              "value": "=Bearer {{ $env.RETELL_API_KEY }}",
              "name": "Authorization"
            },
            {
              "value": "application/json",
              "name": "Content-Type"
            }
          ]
        }
      }
    },
    {
      "id": "wfb-013",
      "name": "CRM Update â€” Next Attempt Scheduled",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        2420,
        160
      ],
      "parameters": {
        "operation": "update",
        "documentId": "={{ $env.GOOGLE_SHEET_ID }}",
        "sheetName": "Leads",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "lead_id": "={{ $json.lead_id }}",
            "status": "=call_initiated_attempt_{{ $json.next_attempt }}",
