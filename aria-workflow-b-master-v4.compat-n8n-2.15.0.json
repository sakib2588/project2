{
  "name": "Aria â€” WORKFLOW B: Retell Call Webhook Handler (v3 Master)",
  "nodes": [
    {
      "id": "wfb-001",
      "name": "Retell Call Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        200,
        300
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "aria-retell-callback",
        "responseMode": "immediately",
        "responseData": "noData"
      },
      "webhookId": "aria-retell-v3"
    },
    {
      "id": "wfb-002",
      "name": "Validate & Classify Call Outcome",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        300
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json || {};\n\nconst call_id = body.call_id || '';\nconst call_status = body.call_status || 'unknown';\nconst disconnection_reason = body.disconnection_reason || 'unknown';\nconst call_duration_sec = body.call_length_second || 0;\nconst call_analysis = body.call_analysis || {};\n\n// Retell echoes back whatever we put in retell_llm_dynamic_variables\nconst dynVars = body.retell_llm_dynamic_variables || {};\nconst lead_id = dynVars.lead_id || '';\nconst attempt_number = parseInt(dynVars.attempt_number || '1', 10);\nconst customer_name = dynVars.customer_name || 'Unknown';\nconst property_value = dynVars.property_value || 'undisclosed';\n\n// Enforce contract\nif (!call_id) throw new Error(`WEBHOOK_MISSING_CALL_ID: body=${JSON.stringify(body).slice(0,200)}`);\nif (!lead_id) throw new Error(`WEBHOOK_MISSING_LEAD_ID: Retell did not echo back lead_id. check dynamic variables in Workflow A.`);\n\n// OUTCOME CLASSIFICATION\n// 'answered' = call ended AND the human actually picked up\n// 'voicemail' = call ended but hit voicemail\n// 'no_answer' = call ended, no one answered\n// 'error' = retell-side error (credits, carrier reject, internal failure)\n// 'unknown' = any unrecognised combination\nconst ANSWERED_REASONS = new Set(['user_hangup', 'agent_hangup', 'call_transfer']);\nlet outcome;\nif (call_status === 'ended' && ANSWERED_REASONS.has(disconnection_reason)) {\n  outcome = 'answered';\n} else if (call_status === 'ended' && disconnection_reason === 'voicemail') {\n  outcome = 'voicemail';\n} else if (call_status === 'ended' && (disconnection_reason === 'no_answer' || disconnection_reason === 'dial_failed')) {\n  outcome = 'no_answer';\n} else if (call_status === 'error') {\n  outcome = 'error'; // CRITICAL FIX #3: errors no longer route to voicemail retry loop\n} else {\n  outcome = 'unknown';\n}\n\nreturn [{ json: {\n  call_id,\n  call_status,\n  disconnection_reason,\n  call_duration_sec,\n  call_summary: call_analysis.call_summary || '',\n  user_sentiment: call_analysis.user_sentiment || 'unknown',\n  lead_id,\n  attempt_number,\n  customer_name,\n  property_value,\n  outcome,\n  received_at: new Date().toISOString()\n}}];"
      }
    },
    {
      "id": "wfb-003",
      "name": "Lookup Lead from CRM",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        640,
        300
      ],
      "parameters": {
        "operation": "read",
        "documentId": "={{ $env.GOOGLE_SHEET_ID }}",
        "sheetName": "Leads",
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "lead_id",
              "lookupValue": "={{ $json.lead_id }}"
            }
          ]
        }
      }
    },
    {
      "id": "wfb-004",
      "name": "Merge Call Data + Lead Record",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        300
      ],
      "parameters": {
        "jsCode": "const callData = $('Validate & Classify Call Outcome').first().json;\nconst crmRow = $input.first().json || {};\n\n// Merge, preferring CRM data for lead fields (it's authoritative)\nreturn [{ json: {\n  ...callData,\n  full_name: crmRow.full_name || callData.customer_name,\n  email: crmRow.email || '',\n  phone: crmRow.phone || '',\n  lead_score: crmRow.lead_score || 0,\n  lead_tier: crmRow.lead_tier || 'C',\n  source: crmRow.source || 'unknown'\n}}];"
      }
    },
    {
      "id": "wfb-005",
      "name": "Route by Call Outcome",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        1080,
        300
      ],
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "loose",
                  "version": 2
                },
                "conditions": [
                  {
                    "id": "80cfc154-6b0e-4d07-befc-fab29fe30ac4",
                    "leftValue": "={{ $json.outcome }}",
                    "rightValue": "answered",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "answered"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "loose",
                  "version": 2
                },
                "conditions": [
                  {
                    "id": "354081ca-2eb5-40fc-b877-0abcf8f551e8",
                    "leftValue": "={{ $json.outcome }}",
                    "rightValue": "voicemail",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "voicemail"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "loose",
                  "version": 2
                },
                "conditions": [
                  {
                    "id": "1ae494d6-4047-4465-a1d9-43edcea5dd93",
                    "leftValue": "={{ $json.outcome }}",
                    "rightValue": "no_answer",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "no_answer"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "loose",
                  "version": 2
                },
                "conditions": [
                  {
                    "id": "08022b7d-7b74-4acb-9e0c-88978d249010",
                    "leftValue": "={{ $json.outcome }}",
                    "rightValue": "error",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "error"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "loose",
                  "version": 2
                },
                "conditions": [
                  {
                    "id": "b4f069b8-0842-4e78-85cf-ce40fb86635e",
                    "leftValue": "={{ $json.outcome }}",
                    "rightValue": "unknown",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "unknown"
            }
          ]
        },
        "options": {}
      }
    },
    {
