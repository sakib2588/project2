          }
        }
      }
    },
    {
      "id": "wfb-018",
      "name": "Slack â€” Lead Exhausted",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [
        2860,
        400
      ],
      "parameters": {
        "authentication": "oAuth2",
        "channel": "#leads-live",
        "text": "=:zzz: *Lead Exhausted â€” 3 No-Answers + Fallback Email Sent*\n\n:bust_in_silhouette: *Name:* {{ $json.full_name }}\n:star: *Tier:* {{ $json.lead_tier }}\n:moneybag: *Property:* ${{ $json.property_value }}\n:id: *Lead ID:* {{ $json.lead_id }}\n\nFallback email sent. Consider manual outreach if Tier A."
      }
    },
    {
      "id": "wfb-019",
      "name": "Slack â€” CRITICAL: Retell Error",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [
        1320,
        520
      ],
      "parameters": {
        "authentication": "oAuth2",
        "channel": "#ops-alerts",
        "text": "=:rotating_light: *CRITICAL â€” Retell Call Error (NOT a voicemail)*\n\nRetell returned `call_status=error` for a call â€” this is a SYSTEM failure, not a lead behaviour.\n\n:id: *Call ID:* {{ $json.call_id }}\n:bust_in_silhouette: *Lead:* {{ $json.full_name }} ({{ $json.lead_id }})\n:warning: *Disconnection Reason:* {{ $json.disconnection_reason }}\n:repeat: *Attempt:* {{ $json.attempt_number }}\n\nPossible causes: Retell credits exhausted, carrier block, invalid E.164 number, Retell API outage.\n\n*Immediate action required. This lead has NOT been retried.*"
      }
    },
    {
      "id": "wfb-020",
      "name": "CRM Update â€” Call Error",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        1540,
        520
      ],
      "parameters": {
        "operation": "update",
        "documentId": "={{ $env.GOOGLE_SHEET_ID }}",
        "sheetName": "Leads",
        "columns": {
